# Honcho config for the hermes-stack (gatekeeper fork) — Qwen3.6 single-engine
#
# Copy to config.toml before `docker compose up` (this file is tracked as a
# template because upstream Honcho .gitignore-s config.toml).
#
#   cp config.toml.hermes-example config.toml
#
# This template targets the single-engine hermes-stack deployment documented
# in ../README.md:
#   * chat llama-server on host at :8080 (OpenAI-compat, alias
#     "qwen3.6-test", serving Qwen3.6-35B-A3B with expert-tensor CPU offload
#     and --reasoning off)
#   * embedding llama-server on host at :8081 (OpenAI-compat, alias
#     "openai/text-embedding-3-small", serving nomic-embed-text)
#   * 768-dim vector store (matches nomic's output), enforced by the
#     `h8i9j0k1l2m3` migration that follows upstream's Vector(1536) creation
#   * No external cloud LLM fallback — each [X.model_config] points at the
#     local chat server via `overrides.base_url`, and OPENAI_API_KEY is set
#     to the placeholder "not-needed" (llama-server ignores the value but
#     refuses empty strings)
#
# Both llama-server processes are managed by ../scripts/llama-services.sh
# (start / stop / status / restart / logs). The legacy two-endpoint
# Bonsai+Ollama design this replaced is archived in
# ../experiments/bonsai-archive.md.
#
# Upstream moved LLM settings from flat `[deriver] PROVIDER/MODEL` fields to
# nested `[X.model_config]` sub-tables with `transport` / `model` keys, plus
# optional `[X.model_config.overrides]` with `base_url` / `api_key_env`.
# This file uses the new schema.
#
# Hyperparameters tuned for the hermes-stack use-case — see
# `../README.md` "Critical Honcho hyperparameters" for rationale:
#   * REPRESENTATION_BATCH_MAX_TOKENS = 200 + FLUSH_ENABLED = true so that
#     short chat turns fire the gatekeeper/deriver pipeline
#   * [embedding] MAX_INPUT_TOKENS = 2048 to match Nomic's native context
#   * [deriver] MAX_INPUT_TOKENS / [deriver.model_config] max_output_tokens
#     sized for tool-loop behavior against the qwen3.6 chat server

[app]
LOG_LEVEL = "INFO"
SESSION_OBSERVERS_LIMIT = 10
GET_CONTEXT_MAX_TOKENS = 100000
MAX_FILE_SIZE = 5242880
MAX_MESSAGE_SIZE = 25000
EMBED_MESSAGES = true
NAMESPACE = "honcho"

[db]
CONNECTION_URI = "postgresql+psycopg://honcho:honcho@database:5432/honcho"
SCHEMA = "public"
POOL_SIZE = 10
MAX_OVERFLOW = 20
POOL_TIMEOUT = 30
POOL_RECYCLE = 300

[auth]
USE_AUTH = false

[cache]
ENABLED = true
URL = "redis://redis:6379/0?suppress=true"
DEFAULT_TTL_SECONDS = 300

# ---------------------------------------------------------------------------
# LLM
#   llama-server requires a non-empty OPENAI_API_KEY even though it ignores
#   the value. The per-module `overrides.base_url` points each subsystem at
#   the local llama-server endpoints on the host.
# ---------------------------------------------------------------------------
[llm]
DEFAULT_MAX_TOKENS = 2500
OPENAI_API_KEY = "not-needed"
# ANTHROPIC_API_KEY = "your-api-key"
# GEMINI_API_KEY = "your-api-key"

# ---------------------------------------------------------------------------
# Embedding — embed llama-server (:8081) serving nomic-embed-text
# ---------------------------------------------------------------------------
[embedding]
# nomic-embed-text outputs 768-dim vectors. The relaxed validator in
# src/config.py (hermes-stack fork) accepts this when vector_store.MIGRATED=true.
VECTOR_DIMENSIONS = 768
# Match nomic-embed-text's 2048-token native context so the chunker splits
# longer messages before they reach the embedding server.
MAX_INPUT_TOKENS = 2048

[embedding.model_config]
transport = "openai"
model = "openai/text-embedding-3-small"

[embedding.model_config.overrides]
base_url = "http://host.docker.internal:8081/v1"

# ---------------------------------------------------------------------------
# Deriver — observation extraction (runs every message, needs tool reliability)
# ---------------------------------------------------------------------------
[deriver]
ENABLED = true
WORKERS = 1
POLLING_SLEEP_INTERVAL_SECONDS = 1.0
STALE_SESSION_TIMEOUT_MINUTES = 5
DEDUPLICATE = true
MAX_INPUT_TOKENS = 8000
WORKING_REPRESENTATION_MAX_OBSERVATIONS = 100
REPRESENTATION_BATCH_MAX_TOKENS = 200
FLUSH_ENABLED = true

[deriver.model_config]
transport = "openai"
model = "qwen3.6-test"
max_output_tokens = 1500

[deriver.model_config.overrides]
base_url = "http://host.docker.internal:8080/v1"

# ---------------------------------------------------------------------------
# Dialectic — multi-level reasoning for peer.chat
# ---------------------------------------------------------------------------
[dialectic]
MAX_OUTPUT_TOKENS = 8192
MAX_INPUT_TOKENS = 100000
HISTORY_TOKEN_LIMIT = 8192
SESSION_HISTORY_MAX_TOKENS = 4096

[dialectic.levels.minimal]
MAX_TOOL_ITERATIONS = 1
MAX_OUTPUT_TOKENS = 250

[dialectic.levels.minimal.model_config]
transport = "openai"
model = "qwen3.6-test"

[dialectic.levels.minimal.model_config.overrides]
base_url = "http://host.docker.internal:8080/v1"

[dialectic.levels.low]
MAX_TOOL_ITERATIONS = 5

[dialectic.levels.low.model_config]
transport = "openai"
model = "qwen3.6-test"

[dialectic.levels.low.model_config.overrides]
base_url = "http://host.docker.internal:8080/v1"

[dialectic.levels.medium]
MAX_TOOL_ITERATIONS = 2

[dialectic.levels.medium.model_config]
transport = "openai"
model = "qwen3.6-test"

[dialectic.levels.medium.model_config.overrides]
base_url = "http://host.docker.internal:8080/v1"

[dialectic.levels.high]
MAX_TOOL_ITERATIONS = 4

[dialectic.levels.high.model_config]
transport = "openai"
model = "qwen3.6-test"

[dialectic.levels.high.model_config.overrides]
base_url = "http://host.docker.internal:8080/v1"

[dialectic.levels.max]
MAX_TOOL_ITERATIONS = 10

[dialectic.levels.max.model_config]
transport = "openai"
model = "qwen3.6-test"

[dialectic.levels.max.model_config.overrides]
base_url = "http://host.docker.internal:8080/v1"

# ---------------------------------------------------------------------------
# Summary — session summarization
# ---------------------------------------------------------------------------
[summary]
ENABLED = true
MESSAGES_PER_SHORT_SUMMARY = 20
MESSAGES_PER_LONG_SUMMARY = 60
MAX_TOKENS_SHORT = 1000
MAX_TOKENS_LONG = 4000

[summary.model_config]
transport = "openai"
model = "qwen3.6-test"

[summary.model_config.overrides]
base_url = "http://host.docker.internal:8080/v1"

# ---------------------------------------------------------------------------
# Dream — memory consolidation (runs rarely)
# ---------------------------------------------------------------------------
# Dream runs on the same chat llama-server as the live Hermes / deriver /
# dialectic paths. Concurrency doesn't matter because dream only fires
# while the user is idle — Honcho cancels pending dreams on new messages.
[dream]
ENABLED = true
DOCUMENT_THRESHOLD = 30
IDLE_TIMEOUT_MINUTES = 10
MIN_HOURS_BETWEEN_DREAMS = 1
ENABLED_TYPES = ["omni"]
MAX_TOOL_ITERATIONS = 3
HISTORY_TOKEN_LIMIT = 8192

[dream.deduction_model_config]
transport = "openai"
model = "qwen3.6-test"

[dream.deduction_model_config.overrides]
base_url = "http://host.docker.internal:8080/v1"

[dream.induction_model_config]
transport = "openai"
model = "qwen3.6-test"

[dream.induction_model_config.overrides]
base_url = "http://host.docker.internal:8080/v1"

[peer_card]
ENABLED = true

[vector_store]
TYPE = "pgvector"
DIMENSIONS = 768
# MIGRATED=true tells the fork's relaxed validator that the schema has
# already been flipped to 768-dim by the h8i9j0k1l2m3 migration — without
# it, startup raises ValueError("must remain 1536 while migration is
# incomplete").
MIGRATED = true

[metrics]
ENABLED = false

[telemetry]
ENABLED = false

[sentry]
ENABLED = false
